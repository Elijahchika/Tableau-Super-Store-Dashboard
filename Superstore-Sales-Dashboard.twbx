      <aliases enabled='yes' />
      <column caption='PROFIT RATIO' datatype='real' name='[Calculation_0455263075655680]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit])/SUM([Sales])' />
      </column>
      <column caption='DISCOUNT AMOUNT' datatype='real' name='[Calculation_0620466108022784]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='[Sales]*[Discount]' />
      </column>
      <column caption='PROFIT PER DISCOUNT' datatype='real' name='[Calculation_0620466113572866]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IIF(SUM([Calculation_0620466108022784])=0,NULL,SUM([Profit])/SUM([Calculation_0620466108022784]))' />
      </column>
      <column caption='Profit Ratio' datatype='real' name='[Calculation_1368249927221915648]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit])/SUM([Sales])' />
      </column>
